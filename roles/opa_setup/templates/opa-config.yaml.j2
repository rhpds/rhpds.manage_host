# OPA Configuration File
# Generated by Ansible - Do not edit manually

services:
{% if opa_bundle_enabled or opa_decision_logs_enabled or opa_status_enabled %}
{% if opa_bundle_enabled and opa_bundle_service %}
  {{ opa_bundle_service }}:
    url: {{ opa_bundle_service }}
{% endif %}
{% if opa_decision_logs_enabled and opa_decision_logs_service %}
  {{ opa_decision_logs_service }}:
    url: {{ opa_decision_logs_service }}
{% endif %}
{% if opa_status_enabled and opa_status_service %}
  {{ opa_status_service }}:
    url: {{ opa_status_service }}
{% endif %}
{% else %}
  {}
{% endif %}

{% if opa_bundle_enabled %}
bundles:
  authz:
{% if opa_bundle_service %}
    service: {{ opa_bundle_service }}
{% endif %}
{% if opa_bundle_resource %}
    resource: {{ opa_bundle_resource }}
{% endif %}
    polling:
      min_delay_seconds: {{ opa_bundle_polling_min_delay }}
      max_delay_seconds: {{ opa_bundle_polling_max_delay }}
{% endif %}

{% if opa_decision_logs_enabled %}
decision_logs:
  console: true
{% if opa_decision_logs_service %}
  service: {{ opa_decision_logs_service }}
{% endif %}
{% if opa_decision_logs_resource %}
  resource: {{ opa_decision_logs_resource }}
{% endif %}
{% endif %}

{% if opa_status_enabled %}
status:
  console: true
{% if opa_status_service %}
  service: {{ opa_status_service }}
{% endif %}
{% endif %}

# Server configuration
server:
  addr: {{ opa_server_addr }}
  diagnostic_addr: {{ opa_diagnostic_addr }}

# Storage
storage:
  disk:
    directory: {{ opa_data_dir }}
